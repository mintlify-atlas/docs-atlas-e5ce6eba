  "keyFeatures": [
    "Patient case management with comprehensive data tracking",
    "AI-powered document analysis for lab reports and radiology images",
    "Automatic SOAP note generation",
    "Primary diagnosis support with ICD-10 codes",
    "Multi-agent AI workflow using LangGraph",
    "Secure authentication and file storage with Supabase",
    "Real-time speech-to-text transcription with Gladia",
    "Responsive web interface built with Next.js"
  ],
  "publicApiSurface": [
    "POST /cases/create_case - Create new patient case with file uploads",
    "GET /cases/all_cases - Retrieve all cases for a user",
    "GET /cases/cases/{case_id} - Get specific case with files and AI insights",
    "PUT /cases/cases/{case_id} - Update case information",
    "DELETE /cases/cases/{case_id} - Delete a case",
    "POST /cases/analyze/{case_id} - Start or complete case analysis",
    "POST /cases/upload - Upload files to a case",
    "GET /cases/files/{case_id} - Get all files for a case",
    "GET /cases/file/{file_id} - Get specific file details",
    "DELETE /cases/file/{file_id} - Delete a file"
  ]
